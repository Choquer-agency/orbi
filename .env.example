# ---------- Local dev ----------
# Database
DATABASE_URL=postgresql://orbi:orbi_dev@localhost:5432/orbi_mail

# Redis
REDIS_URL=redis://localhost:6379

# Auth  (rotate these in production — openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-hex-string
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/accounts/oauth/gmail/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/accounts/oauth/microsoft/callback

# Anthropic
ANTHROPIC_API_KEY=

# Tracking (public URL for email open/click pixels — ngrok in dev, real domain in prod)
TRACKING_BASE_URL=http://localhost:3001

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,ionic://localhost
NODE_ENV=development

# ---------- Production (Railway) ----------
# These are injected by Railway / set via the service's Variables tab:
#   DATABASE_URL, REDIS_URL                  — from Postgres + Redis plugins (reference them)
#   PORT                                     — provided automatically
#   NODE_ENV=production
#   FRONTEND_URL=https://<your-frontend-domain>
#   CORS_ORIGINS=https://<your-frontend-domain>,capacitor://localhost,ionic://localhost
#   TRACKING_BASE_URL=https://<your-backend-domain>
#   GOOGLE_REDIRECT_URI=https://<your-backend-domain>/api/accounts/oauth/gmail/callback
#   MICROSOFT_REDIRECT_URI=https://<your-backend-domain>/api/accounts/oauth/microsoft/callback

# ---------- Mac app signing (local build machine only, in ~/.zshrc) ----------
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# APPLE_ID="you@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="ABCDE12345"
