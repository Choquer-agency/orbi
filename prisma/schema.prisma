generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  avatarUrl    String?
  passwordHash String
  role         UserRole  @default(AGENT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts            Account[]
  comments            ThreadComment[]
  mentionsMade        ThreadMention[]  @relation("MentionedUser")
  reactions           CommentReaction[]
  notifications       Notification[]
  signatures          Signature[]
  threadAccess        ThreadAccess[]
  writingPreferences  WritingPreferences?
  contactStyles       ContactStyle[]
  styleCorrections    StyleCorrection[]
  tasks               Task[]
  scheduledEmails     ScheduledEmail[]
  routingRules        RoutingRule[]
  followUpWatches     FollowUpWatch[]
  handoffsFrom        ThreadHandoff[]      @relation("HandoffFrom")
  handoffsTo          ThreadHandoff[]      @relation("HandoffTo")
  oooAsUser           OutOfOfficeDelegation[] @relation("OooUser")
  oooAsDelegate       OutOfOfficeDelegation[] @relation("OooDelegate")
  delegatedEmails     DelegatedEmail[]
  chatConversations   ChatConversation[]
  triageFeedback      TriageFeedback[]
  triageSettings      TriageSettings?
  trackingExclusions  TrackingExclusion[]
  notificationPreferences NotificationPreferences?
  blockedSenders      BlockedSender[]
  inboxSplits         InboxSplit[]
  aiFilters           AiFilter[]
  snippets            Snippet[]
  deviceTokens        DeviceToken[]
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

model Account {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     AccountProvider
  email        String
  displayName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  scopes       String[]
  isActive     Boolean         @default(true)
  syncCursor   String?
  lastSyncAt   DateTime?
  historicalSyncStatus      HistoricalSyncStatus @default(IDLE)
  historicalSyncProgress    Json?
  historicalSyncCompletedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  emails          Email[]
  threads         Thread[]
  scheduledEmails ScheduledEmail[]

  @@unique([provider, email])
}

enum HistoricalSyncStatus {
  IDLE
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AccountProvider {
  GMAIL
  MICROSOFT
  APPLE_IMAP
}

model Thread {
  id                String   @id @default(uuid())
  accountId         String
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  providerThreadId  String
  subject           String
  snippet           String?
  isRead            Boolean  @default(false)
  isStarred         Boolean  @default(false)
  isArchived        Boolean  @default(false)
  isTrashed         Boolean  @default(false)
  snoozedUntil      DateTime?
  labels            String[]
  participantEmails String[]
  messageCount      Int      @default(0)
  lastMessageAt     DateTime
  lastReceivedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  emails          Email[]
  comments        ThreadComment[]
  mentions        ThreadMention[]
  access          ThreadAccess[]
  tasks             Task[]
  scheduledEmails   ScheduledEmail[]
  followUpWatches   FollowUpWatch[]
  meetingDetections MeetingDetection[]
  handoffs          ThreadHandoff[]

  @@unique([accountId, providerThreadId])
  @@index([accountId, lastMessageAt(sort: Desc)])
  @@index([accountId, lastReceivedAt(sort: Desc)])
  @@index([accountId, isArchived, isTrashed])
  @@index([accountId, snoozedUntil])
}

model Email {
  id                String     @id @default(uuid())
  accountId         String
  account           Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  threadId          String
  thread            Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  providerMessageId String     @unique
  internetMessageId String?
  inReplyTo         String?
  references        String[]
  fromAddress       String
  fromName          String?
  toAddresses       Json
  ccAddresses       Json?
  bccAddresses      Json?
  subject           String
  bodyText          String?
  bodyHtml          String?
  snippet           String?
  isRead            Boolean    @default(false)
  isStarred         Boolean    @default(false)
  isDraft           Boolean    @default(false)
  labels            String[]
  hasAttachments    Boolean    @default(false)
  receivedAt        DateTime
  sentAt            DateTime?
  createdAt         DateTime   @default(now())

  // Send lifecycle fields
  sendStatus       SendStatus @default(NONE)
  undoDeadlineAt   DateTime?
  undoneAt         DateTime?
  sendError        String?     // Last error message if send failed
  sendAttempts     Int         @default(0)  // Number of send attempts made

  attachments       Attachment[]
  classification    EmailClassification?
  tracking          EmailTracking?
  meetingDetections MeetingDetection[]
  delegations       DelegatedEmail[]

  @@index([threadId, receivedAt])
  @@index([accountId, receivedAt(sort: Desc)])
  @@index([sendStatus, undoDeadlineAt])
  @@index([accountId, fromAddress])
  @@index([accountId, fromName])
}

enum SendStatus {
  NONE
  PENDING_SEND
  SENDING        // Currently being sent by worker (prevents double-send)
  SENT
  DELIVERED      // Verified in provider's sent folder
  FAILED         // All retries exhausted — needs manual intervention
  UNDONE
}

model Attachment {
  id                     String   @id @default(uuid())
  emailId                String
  email                  Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename               String
  mimeType               String
  size                   Int
  contentId              String?
  providerAttachmentId   String?
  content                Bytes?
  createdAt              DateTime @default(now())
}

model Signature {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountIds String[]
  name      String
  bodyHtml  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThreadComment {
  id         String    @id @default(uuid())
  threadId   String
  thread     Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  bodyHtml   String
  bodyText   String
  isResolved Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  isEdited   Boolean   @default(false)
  editedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  mentions  ThreadMention[]
  reactions CommentReaction[]
}

model ThreadMention {
  id              String        @id @default(uuid())
  commentId       String
  comment         ThreadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  threadId        String
  thread          Thread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mentionedUserId String
  mentionedUser   User          @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([commentId, mentionedUserId])
}

model CommentReaction {
  id        String        @id @default(uuid())
  commentId String
  comment   ThreadComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime      @default(now())

  @@unique([commentId, userId, emoji])
}

model ThreadAccess {
  id          String      @id @default(uuid())
  threadId    String
  thread      Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessLevel AccessLevel @default(VIEWER)
  grantedAt   DateTime    @default(now())

  @@unique([threadId, userId])
}

enum AccessLevel {
  VIEWER
  COLLABORATOR
  OWNER
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

enum NotificationType {
  NEW_EMAIL
  MENTION
  COMMENT
  ASSIGNMENT
  SLA_WARNING
  SLA_BREACH
  SNOOZE_REMINDER
}

model WritingPreferences {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  greetingStyle String?
  signOffStyle  String?
  tone          Int      @default(3)
  verbosity     Int      @default(3)
  descriptors   String[]
  customRules   String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactStyle {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactEmail  String
  contactName   String?
  tone          Int?
  verbosity     Int?
  greetingStyle String?
  signOffStyle  String?
  notes         String?
  isAutoLearned Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, contactEmail])
}

model StyleCorrection {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactEmail String?
  category     String
  originalText String
  editedText   String
  summary      String?
  threadId     String?
  createdAt    DateTime @default(now())

  @@index([userId, contactEmail])
  @@index([userId, category])
}

model Task {
  id            String     @id @default(uuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId      String
  thread        Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sourceEmailId String?
  description   String
  contactEmail  String?
  contactName   String?
  taskType      TaskType   @default(ACTION_ITEM)
  deadline      DateTime?
  status        TaskStatus @default(OPEN)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId, status, deadline])
  @@index([threadId])
}

enum TaskType {
  PROMISE
  DEADLINE
  CHANGE_REQUEST
  ACTION_ITEM
}

enum TaskStatus {
  OPEN
  DONE
  AUTO_RESOLVED
}

// ─── Scheduled Send ──────────────────────────────────────────────

model ScheduledEmail {
  id            String               @id @default(uuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  threadId      String?
  thread        Thread?              @relation(fields: [threadId], references: [id], onDelete: SetNull)
  parentEmailId String?
  mode          String               @default("compose") // compose | reply | forward
  toAddresses   Json
  ccAddresses   Json?
  bccAddresses  Json?
  subject       String
  bodyHtml      String
  bodyText      String
  sendAt        DateTime
  status        ScheduledEmailStatus @default(SCHEDULED)
  jobId         String?
  sentEmailId   String?
  failureReason String?
  cancelledAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId, status, sendAt])
  @@index([status, sendAt])
}

enum ScheduledEmailStatus {
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

// ─── AI Categorization & Routing ─────────────────────────────────

model EmailClassification {
  id              String   @id @default(uuid())
  emailId         String   @unique
  email           Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  category        String
  confidence      Float
  urgency         String   @default("normal") // low, normal, high, urgent
  summary         String?
  manualOverride  Boolean  @default(false)
  overriddenBy    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([urgency])
}

model RoutingRule {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       String
  assignToUserId String?
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, isActive])
}

// ─── Follow-Up Agent ─────────────────────────────────────────────

model FollowUpWatch {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId     String
  thread       Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  emailId      String
  contactEmail String
  intervals    Int[]              @default([3, 7, 14])
  currentStep  Int                @default(0)
  nextCheckAt  DateTime
  status       FollowUpWatchStatus @default(WATCHING)
  resolvedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  events FollowUpEvent[]

  @@index([userId, status, nextCheckAt])
  @@index([threadId])
}

enum FollowUpWatchStatus {
  WATCHING
  REPLIED
  EXPIRED
  CANCELLED
}

model FollowUpEvent {
  id        String   @id @default(uuid())
  watchId   String
  watch     FollowUpWatch @relation(fields: [watchId], references: [id], onDelete: Cascade)
  type      String   // check, follow_up_drafted, follow_up_sent, reply_received
  draftBody String?
  draftTone String?  // casual, direct, final
  openCount Int?
  createdAt DateTime @default(now())
}

// ─── Open Tracking ───────────────────────────────────────────────

model EmailTracking {
  id           String      @id @default(uuid())
  emailId      String      @unique
  email        Email       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  trackingId   String      @unique @default(uuid())
  isEnabled    Boolean     @default(true)
  openCount    Int         @default(0)
  lastOpenedAt DateTime?
  linkMap      Json?
  createdAt    DateTime    @default(now())

  opens  EmailOpen[]
  clicks LinkClick[]
}

model EmailOpen {
  id         String        @id @default(uuid())
  trackingId String
  tracking   EmailTracking @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)
  openedAt   DateTime      @default(now())
  ipAddress  String?
  userAgent  String?
  country    String?
  city       String?

  @@index([trackingId, openedAt])
}

// ─── Meeting Detection ──────────────────────────────────────────

model MeetingDetection {
  id              String                 @id @default(uuid())
  emailId         String
  email           Email                  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  threadId        String
  thread          Thread                 @relation(fields: [threadId], references: [id], onDelete: Cascade)
  status          MeetingDetectionStatus @default(DETECTED)
  requestedTimes  Json?
  selectedTime    DateTime?
  calendarEventId String?
  summary         String?
  attendees       String[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([threadId])
  @@index([status])
}

enum MeetingDetectionStatus {
  DETECTED
  AVAILABILITY_CHECKED
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── Thread Handoff & OOO Delegation ─────────────────────────────

model ThreadHandoff {
  id                String        @id @default(uuid())
  threadId          String
  thread            Thread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromUserId        String
  fromUser          User          @relation("HandoffFrom", fields: [fromUserId], references: [id])
  toUserId          String
  toUser            User          @relation("HandoffTo", fields: [toUserId], references: [id])
  note              String?
  transferSla       Boolean       @default(false)
  transferFollowUps Boolean       @default(false)
  status            HandoffStatus @default(PENDING)
  acceptedAt        DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())

  @@index([toUserId, status])
  @@index([threadId])
}

enum HandoffStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

model OutOfOfficeDelegation {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation("OooUser", fields: [userId], references: [id], onDelete: Cascade)
  delegateId       String?
  delegate         User?    @relation("OooDelegate", fields: [delegateId], references: [id])
  startAt          DateTime
  endAt            DateTime
  autoReplyEnabled Boolean  @default(false)
  autoReplyBody    String?
  autoReplySubject String?
  autoReplyScope   String   @default("all")
  isActive         Boolean  @default(true)
  categories       String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  autoReplyLogs AutoReplyLog[]

  @@index([userId, isActive])
}

model DelegatedEmail {
  id            String               @id @default(uuid())
  emailId       String
  email         Email                @relation(fields: [emailId], references: [id], onDelete: Cascade)
  delegatedToId String
  delegatedTo   User                 @relation(fields: [delegatedToId], references: [id])
  status        DelegatedEmailStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([delegatedToId, status])
}

enum DelegatedEmailStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  RETURNED
}

// ─── Contacts ────────────────────────────────────────────────────

model Person {
  id          String   @id @default(uuid())
  userId      String
  displayName String
  company     String?
  title       String?
  phone       String?
  avatarUrl   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    Contact[]

  @@index([userId, displayName])
  @@index([userId, updatedAt(sort: Desc)])
}

model Contact {
  id           String   @id @default(uuid())
  userId       String
  email        String
  name         String?
  company      String?
  title        String?
  phone        String?
  avatarUrl    String?
  notes        String?
  lastEmailed  DateTime?
  emailCount   Int      @default(0)
  isAutoLearned Boolean @default(true)
  personId     String?
  person       Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, email])
  @@index([userId, name])
  @@index([userId, company])
  @@index([userId, lastEmailed(sort: Desc)])
  @@index([personId])
}

// ── AI Chat History ──

model ChatConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?  // auto-generated from first message
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // 'user' | 'assistant'
  content        String
  metadata       Json?            // stores draft, searchResults, threadReferences, priorityInbox, tasks, contactResults
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

// ─── Smart Triage ────────────────────────────────────────────

model TriageFeedback {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId           String?
  threadId          String?
  suggestedCategory String
  finalCategory     String
  wasConfirmed      Boolean
  senderAddress     String
  subjectSnippet    String
  createdAt         DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, senderAddress])
}

model TriageSettings {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoSortEnabled     Boolean  @default(false)
  confidenceThreshold Float    @default(0.85)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TrackingExclusion {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress String
  reason       String?
  createdAt    DateTime @default(now())

  @@unique([userId, emailAddress])
  @@index([userId])
}

// ── Settings Feature Expansion ──────────────────────────────────────────────

model NotificationPreferences {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enableNewEmail   Boolean  @default(true)
  enableMention    Boolean  @default(true)
  enableComment    Boolean  @default(true)
  enableAssignment Boolean  @default(true)
  enableSlaWarning Boolean  @default(true)
  enableSlaBreach  Boolean  @default(true)
  enableSnoozeReminder Boolean @default(true)
  desktopEnabled   Boolean  @default(false)
  soundEnabled     Boolean  @default(false)
  pushEnabled          Boolean  @default(true)
  showPreviewOnLock    Boolean  @default(true)
  quietHoursStart      String?
  quietHoursEnd        String?
  quietHoursTimezone   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlockedSender {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress String?
  domain       String?
  reason       String?
  createdAt    DateTime @default(now())

  @@unique([userId, emailAddress])
  @@unique([userId, domain])
  @@index([userId])
}

model InboxSplit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  label     String
  position  Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, category])
  @@index([userId, isEnabled, position])
}

model AiFilter {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String
  conditions    Json
  actions       Json
  isActive      Boolean   @default(true)
  matchCount    Int       @default(0)
  lastMatchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, isActive])
}

model LinkClick {
  id          String        @id @default(uuid())
  trackingId  String
  tracking    EmailTracking @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)
  originalUrl String
  clickedAt   DateTime      @default(now())
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?

  @@index([trackingId, clickedAt])
}

model AutoReplyLog {
  id             String                @id @default(uuid())
  delegationId   String
  delegation     OutOfOfficeDelegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  senderAddress  String
  repliedAt      DateTime              @default(now())

  @@unique([delegationId, senderAddress])
  @@index([delegationId, senderAddress])
}

model Snippet {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  bodyHtml  String
  bodyText  String
  category  String?
  variables String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
}

// ─── Push Notifications ─────────────────────────────────────────

model DeviceToken {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String         @unique
  platform    DevicePlatform
  bundleId    String         @default("com.orbimail.app")
  sandbox     Boolean        @default(false)
  appVersion  String?
  lastUsedAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([token])
}

enum DevicePlatform {
  IOS
  ANDROID
}

model PushDeliveryLog {
  id              String   @id @default(uuid())
  userId          String
  deviceTokenId   String
  notificationId  String?
  apnsId          String?
  status          String   // sent, failed, token_invalid, rate_limited
  errorMessage    String?
  errorCode       Int?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([deviceTokenId])
  @@index([status, createdAt])
}
